# --- LLM provider: openai | groq ---
LLM_PROVIDER=groq

# --- OpenAI (when LLM_PROVIDER=openai; optional for embeddings with Groq) ---
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# --- Groq (when LLM_PROVIDER=groq) — https://console.groq.com ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# --- YouTube (production on Render / cloud) ---
# Render blocks direct youtube.com scraping. Set these for reliable metadata + transcripts:
#   YOUTUBE_API_KEY — free at console.cloud.google.com (duration, upload date, comments)
#   SUPADATA_API_KEY — optional transcript fallback when captions are blocked (supadata.ai)
#   SERP_API_KEY     — SerpApi YouTube Video Transcript (recommended on Render; serpapi.com)
# Optional on Render AND Vercel (frontend /api/youtube/metadata proxy for duration + subscribers)
YOUTUBE_API_KEY=
SUPADATA_API_KEY=
SERP_API_KEY=

# Apify — Instagram via crawlerbros/instagram-transcript-scraper (Whisper transcripts)
APIFY_API_KEY=

# Vercel URL for YouTube proxy routes (defaults to first https:// CORS origin).
# Example: FRONTEND_PROXY_URL=https://vanadium-delta.vercel.app
FRONTEND_PROXY_URL=

# --- Vector store & analysis persistence ---
# Local dev: relative paths under backend/
# Production (Docker/Render): mount a volume at /data and use:
#   CHROMA_PERSIST_DIR=/data/chroma
#   ANALYSIS_PERSIST_DIR=/data/analyses
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION=vanadium_chunks
ANALYSIS_PERSIST_DIR=./data/analyses

# --- Chunking ---
CHUNK_SIZE=600
CHUNK_OVERLAP=100

# --- Retrieval ---
RETRIEVAL_TOP_K=4          # chunks retrieved per video
MEMORY_MAX_TURNS=8         # conversation turns kept per analysis

# --- Server ---
HOST=0.0.0.0
PORT=8000
# Comma-separated allowed browser origins (required in production).
# Example: CORS_ORIGINS=https://vanadium.vercel.app,https://yourdomain.com
CORS_ORIGINS=http://localhost:3000

# --- Audio → text (Groq Whisper) ---
# Instagram Reels: always audio + Groq Whisper when ENABLE_WHISPER=true.
# YouTube: tries captions first (Vercel proxy), then Groq Whisper if captions fail.
# Requires GROQ_API_KEY. Set WHISPER_PROVIDER=groq in production (recommended).
WHISPER_PROVIDER=groq
WHISPER_MODEL=base
GROQ_WHISPER_MODEL=whisper-large-v3-turbo
ENABLE_WHISPER=true

# --- Visual understanding (vision LLM reads scene + on-screen text) ---
# Runs for every video when ENABLE_VISUAL=true and an LLM key is configured.
ENABLE_VISUAL=false
# OCR fallback when vision LLM is unavailable (Docker: tesseract is on PATH).
ENABLE_OCR=false
# Leave empty on Linux/Docker (/usr/bin/tesseract). Windows example:
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=
VISUAL_MAX_FRAMES=4
VISUAL_MAX_HEIGHT=480

# --- Instagram authentication (for yt-dlp) ---
# Often required in production for reliable IG views/likes and reel downloads.
# Provide ONE of:
#   INSTAGRAM_COOKIES_FILE=/secrets/instagram_cookies.txt
#   COOKIES_FROM_BROWSER=chrome
# INSTAGRAM_COOKIES_FILE=
# COOKIES_FROM_BROWSER=
