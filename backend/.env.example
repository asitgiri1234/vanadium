# --- LLM provider: openai | groq ---
LLM_PROVIDER=groq

# --- OpenAI (when LLM_PROVIDER=openai; optional for embeddings with Groq) ---
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# --- Groq (when LLM_PROVIDER=groq) — https://console.groq.com ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# --- Vector store ---
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION=vanadium_chunks

# --- Chunking ---
CHUNK_SIZE=600
CHUNK_OVERLAP=100

# --- Retrieval ---
RETRIEVAL_TOP_K=4          # chunks retrieved per video
MEMORY_MAX_TURNS=8         # conversation turns kept per analysis

# --- Server ---
HOST=0.0.0.0
PORT=8000
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000

# --- Instagram transcription ---
# whisper model size: tiny | base | small | medium | large
WHISPER_MODEL=base
ENABLE_WHISPER=false

# --- Visual understanding (vision LLM reads scene + on-screen text) ---
# Runs for every video when ENABLE_VISUAL=true and an LLM key is configured.
ENABLE_VISUAL=false
# OCR fallback only when no LLM key (not recommended — noisy on social video).
ENABLE_OCR=false
TESSERACT_CMD=
VISUAL_MAX_FRAMES=4
VISUAL_MAX_HEIGHT=480

# --- Instagram authentication (for yt-dlp) ---
# INSTAGRAM_COOKIES_FILE=C:\path\to\instagram_cookies.txt
# COOKIES_FROM_BROWSER=chrome
