# --- OpenAI ---
# Without a key, Vanadium falls back to a local embedder + extractive analyst.
OPENAI_API_KEY=

# Models
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# --- Vector store ---
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION=vanadium_chunks

# --- Chunking ---
CHUNK_SIZE=600
CHUNK_OVERLAP=100

# --- Retrieval ---
RETRIEVAL_TOP_K=4          # chunks retrieved per video
MEMORY_MAX_TURNS=8         # conversation turns kept per analysis

# --- Server ---
HOST=0.0.0.0
PORT=8000
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000

# --- Instagram transcription ---
# whisper model size: tiny | base | small | medium | large
WHISPER_MODEL=base
ENABLE_WHISPER=false

# --- Visual understanding (frame OCR + optional scene description) ---
# Reads on-screen text from sampled frames; great for music-only / text-overlay
# reels. Scene descriptions ("an elegant woman in white at a restaurant") are
# produced by the vision LLM only when OPENAI_API_KEY is set.
ENABLE_VISUAL=false
# OCR is only used when no OpenAI key is set. With a key, vision reads text instead.
ENABLE_OCR=false
# Path to the Tesseract binary (only if ENABLE_OCR=true). On Windows:
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=
VISUAL_MAX_FRAMES=4        # max frames sampled across the video
VISUAL_MAX_HEIGHT=480      # cap download resolution for speed

# --- Instagram authentication (for yt-dlp) ---
# Instagram only reports view/play counts on its authenticated API path.
# Provide ONE of the following from a logged-in session:
#
#   1. A Netscape-format cookies.txt (export with a browser extension like
#      "Get cookies.txt LOCALLY" while logged into instagram.com):
# INSTAGRAM_COOKIES_FILE=C:\path\to\instagram_cookies.txt
#
#   2. Read cookies directly from an installed browser profile
#      (chrome | edge | firefox | brave | opera | vivaldi | chromium):
# COOKIES_FROM_BROWSER=chrome
