# --- OpenAI ---
# Without a key, Vanadium falls back to a local embedder + extractive analyst.
OPENAI_API_KEY=

# Models
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# --- Vector store ---
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION=vanadium_chunks

# --- Chunking ---
CHUNK_SIZE=600
CHUNK_OVERLAP=100

# --- Retrieval ---
RETRIEVAL_TOP_K=4          # chunks retrieved per video
MEMORY_MAX_TURNS=8         # conversation turns kept per analysis

# --- Server ---
HOST=0.0.0.0
PORT=8000
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000

# --- Instagram transcription ---
# whisper model size: tiny | base | small | medium | large
WHISPER_MODEL=base
ENABLE_WHISPER=false
